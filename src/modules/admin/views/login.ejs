<%- include('partials/_head', { title: 'Login' }) %>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">

  <div class="w-full max-w-sm">
    <div class="bg-white rounded-2xl shadow-lg px-8 py-10">
      <h1 class="text-xl font-bold text-slate-800 mb-1">Eventlink Admin</h1>
      <p class="text-sm text-gray-500 mb-7">Sign in to your account</p>

      <% if (error) { %>
        <div class="mb-5 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-600">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email or username</label>
          <input type="text" name="email" required autofocus autocomplete="username"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input type="password" name="password" required
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400"/>
        </div>
        <button type="submit"
          class="w-full bg-slate-900 hover:bg-slate-700 text-white font-medium rounded-lg py-2.5 text-sm transition-colors">
          Login
        </button>
      </form>
    </div>
  </div>

<%- include('partials/_foot') %>
