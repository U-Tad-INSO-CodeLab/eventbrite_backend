<%
  const formatHeader = s => {
    const words = s.split('_')
    if (words[words.length - 1] === 'id') words.pop()
    return words.map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
  }

  const fieldMetaMap = {}
  for (const f of config.editFields) fieldMetaMap[f.name] = f

  const formatEnumCell = s =>
    String(s).split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ')
%>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800"><%= config.label %></h1>
  </div>
  <a href="/admin/<%= modelKey %>/new"
    class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
    + Create
  </a>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 bg-slate-50">
        <% for (const f of config.listFields) { %>
          <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
            <%= formatHeader(f) %>
          </th>
        <% } %>
        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% if (rows.length === 0) { %>
        <tr>
          <td colspan="<%= config.listFields.length + 1 %>"
            class="px-4 py-12 text-center text-slate-400 text-sm">
            No records found.
          </td>
        </tr>
      <% } %>
      <% for (const row of rows) { %>
        <tr class="hover:bg-slate-50 transition-colors">
          <% for (const f of config.listFields) { %>
            <td class="px-4 py-3 max-w-[180px] truncate text-slate-600">
              <%
                const meta = fieldMetaMap[f]
                const raw = row[f]
              %>

              <% if (meta && meta.type === 'relation' && relationLookups[f] != null) { %>
                <span class="text-slate-800"><%= relationLookups[f][raw] ?? raw %></span>

              <% } else if (meta && meta.type === 'boolean' || typeof raw === 'boolean') { %>
                <% if (raw) { %>
                  <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-100 text-emerald-600" title="Yes">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-100 text-red-500" title="No">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </span>
                <% } %>

              <% } else if (meta && meta.type === 'enum' && raw != null && raw !== '') { %>
                <span class="text-slate-800"><%= formatEnumCell(raw) %></span>

              <% } else if (meta && meta.type === 'datetime' && raw) { %>
                <span class="text-slate-500 text-xs"><%= new Date(raw).toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' }) %></span>

              <% } else { %>
                <%= raw ?? '' %>
              <% } %>
            </td>
          <% } %>
          <td class="px-4 py-3">
            <div class="flex items-center gap-1">
              <a href="/admin/<%= modelKey %>/<%= row.id %>/edit"
                title="Edit"
                class="p-1.5 rounded-md text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </a>
              <form method="POST" action="/admin/<%= modelKey %>/<%= row.id %>/delete"
                onsubmit="return confirm('Delete this record?')">
                <button type="submit" title="Delete"
                  class="p-1.5 rounded-md text-slate-400 hover:text-red-500 hover:bg-red-50 bg-transparent border-none cursor-pointer transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                  </svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
