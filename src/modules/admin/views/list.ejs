<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-bold text-slate-800"><%= config.label %></h2>
  <a href="/admin/<%= modelKey %>/new"
    class="bg-slate-900 hover:bg-slate-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
    + Create
  </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-slate-900 text-white">
        <% for (const f of config.listFields) { %>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider"><%= f %></th>
        <% } %>
        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if (rows.length === 0) { %>
        <tr>
          <td colspan="<%= config.listFields.length + 1 %>"
            class="px-4 py-10 text-center text-gray-400 text-sm">
            No records found.
          </td>
        </tr>
      <% } %>
      <% for (const row of rows) { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <% for (const f of config.listFields) { %>
            <td class="px-4 py-3 max-w-[180px] truncate text-gray-700"><%= row[f] ?? '' %></td>
          <% } %>
          <td class="px-4 py-3 flex items-center gap-4">
            <a href="/admin/<%= modelKey %>/<%= row.id %>/edit"
              class="text-blue-600 hover:text-blue-800 font-medium transition-colors">Edit</a>
            <form method="POST" action="/admin/<%= modelKey %>/<%= row.id %>/delete"
              onsubmit="return confirm('Delete this record?')">
              <button type="submit"
                class="text-red-500 hover:text-red-700 font-medium bg-transparent border-none cursor-pointer p-0 text-sm transition-colors">
                Delete
              </button>
            </form>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
