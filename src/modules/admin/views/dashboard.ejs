<div class="mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Dashboard</h1>
  <p class="text-slate-500 text-sm mt-1">Select a model to manage records.</p>
</div>

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
  <% for (const [key, cfg] of Object.entries(models)) { %>
    <a href="/admin/<%= key %>"
      class="bg-white border border-slate-200 rounded-xl px-5 py-4 hover:border-indigo-300 hover:shadow-md transition-all group">
      <p class="font-semibold text-slate-700 group-hover:text-indigo-600 transition-colors"><%= cfg.label %></p>
      <p class="text-xs text-slate-400 mt-1">Manage →</p>
    </a>
  <% } %>
</div>
