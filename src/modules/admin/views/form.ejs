<% const formatLabel = s => s.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') %>

<div class="mb-6">
  <a href="/admin/<%= modelKey %>"
    class="inline-flex items-center text-sm text-slate-400 hover:text-slate-700 transition-colors">
    ← Back to <%= config.label %>
  </a>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-7 max-w-xl">
  <h1 class="text-xl font-bold text-slate-800 mb-6">
    <%= row ? 'Edit' : 'Create' %> <%= config.label %>
  </h1>

  <form method="POST" action="/admin/<%= modelKey %><%= row ? '/' + row.id : '' %>" class="space-y-5">

    <% for (const field of config.editFields) { %>
      <% const v = row && row[field.name] != null ? String(row[field.name]) : '' %>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">
          <%= formatLabel(field.name) %>
          <% if (field.optional) { %>
            <span class="text-slate-400 font-normal text-xs ml-1">(optional)</span>
          <% } %>
        </label>

        <% const inputClass = "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition" %>

        <% if (field.type === 'text') { %>
          <textarea name="<%= field.name %>"
            class="<%= inputClass %> min-h-[80px] resize-y"><%= v %></textarea>

        <% } else if (field.type === 'boolean') { %>
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="<%= field.name %>" value="true"
              <%= v === 'true' ? 'checked' : '' %>
              class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-400"/>
            <span class="text-sm text-slate-600"><%= field.name %></span>
          </label>

        <% } else if (field.type === 'number') { %>
          <input type="number" name="<%= field.name %>" value="<%= v %>" class="<%= inputClass %>"/>

        <% } else if (field.type === 'datetime') { %>
          <% const dtVal = v ? new Date(v).toISOString().slice(0, 16) : '' %>
          <input type="datetime-local" name="<%= field.name %>" value="<%= dtVal %>" class="<%= inputClass %>"/>

        <% } else if (field.type === 'password') { %>
          <input type="password" name="<%= field.name %>" autocomplete="new-password"
            placeholder="<%= row ? 'Leave blank to keep unchanged' : '' %>"
            class="<%= inputClass %>"/>

        <% } else { %>
          <input type="text" name="<%= field.name %>" value="<%= v %>" class="<%= inputClass %>"/>
        <% } %>
      </div>
    <% } %>

    <div class="pt-2">
      <button type="submit"
        class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-2.5 rounded-lg text-sm transition-colors">
        <%= row ? 'Save changes' : 'Create' %>
      </button>
    </div>
  </form>
</div>
