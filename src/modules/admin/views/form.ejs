<a href="/admin/<%= modelKey %>"
  class="inline-flex items-center text-sm text-gray-500 hover:text-gray-800 mb-5 transition-colors">
  ← Back to <%= config.label %>
</a>

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-7 max-w-xl">
  <h2 class="text-xl font-bold text-slate-800 mb-6">
    <%= row ? 'Edit' : 'Create' %> <%= config.label %>
  </h2>

  <form method="POST" action="/admin/<%= modelKey %><%= row ? '/' + row.id : '' %>" class="space-y-5">

    <% for (const field of config.editFields) { %>
      <% const v = row && row[field.name] != null ? String(row[field.name]) : '' %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          <%= field.name %>
          <% if (field.optional) { %>
            <span class="text-gray-400 font-normal text-xs ml-1">(optional)</span>
          <% } %>
        </label>

        <% const inputClass = "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>

        <% if (field.type === 'text') { %>
          <textarea name="<%= field.name %>"
            class="<%= inputClass %> min-h-[80px] resize-y"><%= v %></textarea>

        <% } else if (field.type === 'boolean') { %>
          <label class="inline-flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="<%= field.name %>" value="true"
              <%= v === 'true' ? 'checked' : '' %>
              class="w-4 h-4 rounded border-gray-300 text-slate-800 focus:ring-slate-400"/>
            <span class="text-sm text-gray-600"><%= field.name %></span>
          </label>

        <% } else if (field.type === 'number') { %>
          <input type="number" name="<%= field.name %>" value="<%= v %>"
            class="<%= inputClass %>"/>

        <% } else if (field.type === 'datetime') { %>
          <% const dtVal = v ? new Date(v).toISOString().slice(0, 16) : '' %>
          <input type="datetime-local" name="<%= field.name %>" value="<%= dtVal %>"
            class="<%= inputClass %>"/>

        <% } else if (field.type === 'password') { %>
          <input type="password" name="<%= field.name %>" autocomplete="new-password"
            placeholder="<%= row ? 'Leave blank to keep unchanged' : '' %>"
            class="<%= inputClass %>"/>

        <% } else { %>
          <input type="text" name="<%= field.name %>" value="<%= v %>"
            class="<%= inputClass %>"/>
        <% } %>
      </div>
    <% } %>

    <div class="pt-2">
      <button type="submit"
        class="bg-slate-900 hover:bg-slate-700 text-white font-medium px-6 py-2.5 rounded-lg text-sm transition-colors">
        <%= row ? 'Save changes' : 'Create' %>
      </button>
    </div>
  </form>
</div>
