PORT=3000
NODE_ENV=development

# Production: comma-separated browser origins allowed for CORS (e.g. https://app.example.com).
# In development, all origins are allowed. Ignored when NODE_ENV is not production.
CORS_ORIGINS="https://app.example.com,https://www.example.com"

# App builds env.DATABASE_URL (for Prisma) from these; same DB as Prisma client adapter (env.db).
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_USER="username"
DATABASE_PASSWORD="password"
DATABASE_NAME="mydb"

# Signed cookie secret for express-session (MySQL-backed store).
SESSION_SECRET="change-me-in-production"

# Ably API key (from your Ably dashboard — keep this server-side only).
ABLY_API_KEY="your-ably-api-key"
